{
	"private": false,
	"version": "0.1.0",
	"name": "@apps/express",
	"description": "REST API server built with Express.js and TypeScript",
	"type": "module",
	"scripts": {
		"start": "bun dist/index.js",
		"dev": "tsup src/index.ts --watch --onSuccess 'bun dist/index.js'",
		"build": "tsup src/index.ts",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@packages/utils": "workspace:*",
		"body-parser": "2.2.2",
		"cors": "2.8.6",
		"express": "5.2.1",
		"morgan": "1.11.0"
	},
	"devDependencies": {
		"@tools/tests-preset": "workspace:*",
		"@tools/typescript": "workspace:*",
		"@types/bun": "1.3.14",
		"@types/body-parser": "1.19.6",
		"@types/cors": "2.8.19",
		"@types/express": "5.0.6",
		"@types/morgan": "1.9.10",
		"@types/supertest": "7.2.1",
		"supertest": "7.2.2",
		"tsup": "8.5.1"
	}
}
