{
	"private": true,
	"name": "@apps/astro-ssg",
	"description": "Documentation site built with Astro for the monobun project",
	"type": "module",
	"scripts": {
		"astro": "bun --bun x astro",
		"dev": "bun run astro dev",
		"build": "bun run astro build",
		"start": "bun run astro preview",
		"lint": "bun run astro check && biome check .",
		"typecheck": "bun run astro check && tsc --noEmit --project tsconfig.ts.json"
	},
	"dependencies": {
		"@astrojs/tailwind": "6.0.2",
		"@packages/ui": "workspace:*",
		"@tailwindcss/typography": "0.5.19",
		"astro": "6.3.6",
		"lucide-astro": "0.556.0",
		"marked": "18.0.4"
	},
	"devDependencies": {
		"@astrojs/check": "0.9.9",
		"@tools/typescript": "workspace:*",
		"@types/bun": "1.3.14",
		"@tailwindcss/vite": "4.3.0",
		"tailwindcss": "4.3.0",
		"tw-animate-css": "1.4.0",
		"typescript": "6.0.3"
	}
}
