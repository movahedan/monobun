---
import Layout from '../layouts/Layout.astro';
---

<Layout title='Project Documentation'>
  <div class='bg-white'>
    <!-- Hero section -->
    <div class='relative isolate px-6 pt-14 lg:px-8'>
      <div class='mx-auto max-w-2xl py-32 sm:py-48 lg:py-56'>
        <div class='text-center'>
          <h1
            class='text-4xl font-bold tracking-tight text-gray-900 sm:text-6xl'
          >
            📚 Project Documentation
          </h1>
          <p class='mt-6 text-lg leading-8 text-gray-600'>
            Comprehensive documentation for development workflows, setup guides,
            and best practices. Everything you need to know about this project
            in one place.
          </p>
          <div class='mt-10 flex items-center justify-center gap-x-6'>
            <a
              href='/docs/GETTING_STARTED'
              class='rounded-md bg-indigo-600 px-3.5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600'
            >
              Get started
            </a>
            <a
              href='/docs/GETTING_STARTED'
              class='text-sm font-semibold leading-6 text-gray-900'
            >
              Dev stack (Docker) <span aria-hidden='true'>→</span>
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Quick links section -->
    <div class='bg-gray-50 py-24 sm:py-32'>
      <div class='mx-auto max-w-7xl px-6 lg:px-8'>
        <div class='mx-auto max-w-2xl lg:max-w-none'>
          <h2
            class='text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl'
          >
            Quick Navigation
          </h2>
          <div
            class='mt-16 grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3'
          >
            <!-- Getting started -->
            <div
              class='group relative bg-white p-6 focus-within:ring-2 focus-within:ring-inset focus-within:ring-indigo-500'
            >
              <div>
                <span
                  class='inline-flex rounded-lg bg-indigo-50 p-3 text-indigo-700 ring-4 ring-white'
                >
                  📖
                </span>
              </div>
              <div class='mt-8'>
                <h3 class='text-lg font-medium'>
                  <a
                    href='/docs/GETTING_STARTED'
                    class='focus:outline-none'
                  >
                    <span class='absolute inset-0' aria-hidden='true'></span>
                    Getting started
                  </a>
                </h3>
                <p class='mt-2 text-sm text-gray-500'>
                  Install tooling, local bootstrap, dev compose, quality gate,
                  and command cheat sheet.
                </p>
              </div>
            </div>

            <!-- Scripting -->
            <div
              class='group relative bg-white p-6 focus-within:ring-2 focus-within:ring-inset focus-within:ring-indigo-500'
            >
              <div>
                <span
                  class='inline-flex rounded-lg bg-teal-50 p-3 text-teal-700 ring-4 ring-white'
                >
                  🧩
                </span>
              </div>
              <div class='mt-8'>
                <h3 class='text-lg font-medium'>
                  <a href='/docs/SCRIPTING' class='focus:outline-none'>
                    <span class='absolute inset-0' aria-hidden='true'></span>
                    Scripting
                  </a>
                </h3>
                <p class='mt-2 text-sm text-gray-500'>
                  Bun CLIs under <code class='text-xs'>tools/scripts/</code>, Ink, parseArgs, and Intershell entities.
                </p>
              </div>
            </div>

            <!-- Auto versioning -->
            <div
              class='group relative bg-white p-6 focus-within:ring-2 focus-within:ring-inset focus-within:ring-indigo-500'
            >
              <div>
                <span
                  class='inline-flex rounded-lg bg-amber-50 p-3 text-amber-800 ring-4 ring-white'
                >
                  🏷️
                </span>
              </div>
              <div class='mt-8'>
                <h3 class='text-lg font-medium'>
                  <a href='/docs/AUTO_VERSIONING' class='focus:outline-none'>
                    <span class='absolute inset-0' aria-hidden='true'></span>
                    Auto versioning
                  </a>
                </h3>
                <p class='mt-2 text-sm text-gray-500'>
                  Prepare, apply, and CI flows for releases and changelogs.
                </p>
              </div>
            </div>

            <!-- Quality Checklist -->
            <div
              class='group relative bg-white p-6 focus-within:ring-2 focus-within:ring-inset focus-within:ring-indigo-500'
            >
              <div>
                <span
                  class='inline-flex rounded-lg bg-yellow-50 p-3 text-yellow-700 ring-4 ring-white'
                >
                  ✅
                </span>
              </div>
              <div class='mt-8'>
                <h3 class='text-lg font-medium'>
                  <a
                    href='/docs/0_QUALITY_CHECKLIST'
                    class='focus:outline-none'
                  >
                    <span class='absolute inset-0' aria-hidden='true'></span>
                    Quality Checklist
                  </a>
                </h3>
                <p class='mt-2 text-sm text-gray-500'>
                  Standards and requirements for maintaining code quality and
                  consistency.
                </p>
              </div>
            </div>

            <!-- Testing -->
            <div
              class='group relative bg-white p-6 focus-within:ring-2 focus-within:ring-inset focus-within:ring-indigo-500'
            >
              <div>
                <span
                  class='inline-flex rounded-lg bg-purple-50 p-3 text-purple-700 ring-4 ring-white'
                >
                  🧪
                </span>
              </div>
              <div class='mt-8'>
                <h3 class='text-lg font-medium'>
                  <a href='/docs/TESTING' class='focus:outline-none'>
                    <span class='absolute inset-0' aria-hidden='true'></span>
                    Testing
                  </a>
                </h3>
                <p class='mt-2 text-sm text-gray-500'>
                  Testing strategies, tools, and best practices for the project.
                </p>
              </div>
            </div>

            <!-- AI Prompt -->
            <div
              class='group relative bg-white p-6 focus-within:ring-2 focus-within:ring-inset focus-within:ring-indigo-500'
            >
              <div>
                <span
                  class='inline-flex rounded-lg bg-pink-50 p-3 text-pink-700 ring-4 ring-white'
                >
                  🤖
                </span>
              </div>
              <div class='mt-8'>
                <h3 class='text-lg font-medium'>
                  <a href='/docs/AI_Prompt' class='focus:outline-none'>
                    <span class='absolute inset-0' aria-hidden='true'></span>
                    AI Development Assistant
                  </a>
                </h3>
                <p class='mt-2 text-sm text-gray-500'>
                  Guidelines for AI-assisted development and documentation
                  standards.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>
