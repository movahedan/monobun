---
import Layout from '../../layouts/Layout.astro';

export const prerender = true;

export async function getStaticPaths() {
	const docs = [
		'0_QUALITY_CHECKLIST',
		'CHEATSHEET',
		'SCRIPTING',
		'AUTO_VERSIONING',
		'TESTING',
		'AI_Prompt',
		'1_INSTALLATION_GUIDE',
		'2_SETUP_FLOWS',
		'3_DEV_FLOWS',
		'4_INTERSHELL',
		'5_DOCKER',
		'6_RENOVATE',
		'7_AUTO_VERSIONING',
	];

	return docs.map((doc) => ({
		params: { slug: doc },
		props: { doc },
	}));
}

const doc = Astro.props.doc;

let content = '';
let title = doc;

const movedToRepoDocs =
	'<p>Setup: <code>README.md</code> (Quick start). Repo map and compose: <code>AGENTS.md</code>. Commands: <a href="/docs/CHEATSHEET">CHEATSHEET</a> or <code>docs/CHEATSHEET.md</code>.</p>';

const movedToScripting =
	'<p>Scripting documentation moved to <a href="/docs/SCRIPTING">Scripting</a>. Read <code>docs/SCRIPTING.md</code> in the repo.</p>';

const movedToAutoVersioning =
	'<p>Auto versioning documentation moved to <a href="/docs/AUTO_VERSIONING">Auto versioning</a>. Read <code>docs/AUTO_VERSIONING.md</code> in the repo.</p>';

const dockerComposeNote =
	'<p>Docker and Compose usage: <code>README.md</code> (Quick start) and <code>AGENTS.md</code> (dev stack on the host).</p>';

const renovateNote =
	'<p>Renovate is configured in <code>renovate.json</code> at the repo root. See <a href="https://docs.renovatebot.com/">Renovate documentation</a> for DSL and options.</p>';

const docContent: Record<string, { title: string; content: string }> = {
	'0_QUALITY_CHECKLIST': {
		title: '✅ Quality Checklist',
		content:
			'<h1>Quality Checklist</h1><p>This page contains the quality checklist for the project.</p>',
	},
	CHEATSHEET: {
		title: '⚡ Command cheatsheet',
		content:
			'<h1>Command cheatsheet</h1><p>All root <code>bun run</code> commands in tables. Authoritative copy: <code>docs/CHEATSHEET.md</code> in the repository. Setup: <code>README.md</code> · Map: <code>AGENTS.md</code>.</p>',
	},
	SCRIPTING: {
		title: '🧩 Scripting',
		content:
			'<h1>Scripting</h1><p>Bun CLIs under <code>tools/scripts/</code>, Ink, parseArgs, and Intershell entities. Open <code>docs/SCRIPTING.md</code> in the repository for the authoritative copy.</p>',
	},
	AUTO_VERSIONING: {
		title: '🏷️ Auto versioning',
		content:
			'<h1>Auto versioning</h1><p><code>bun run release prepare|apply|ci</code>, tags, and changelogs. Open <code>docs/AUTO_VERSIONING.md</code> in the repository for the authoritative copy.</p>',
	},
	'1_INSTALLATION_GUIDE': {
		title: '📦 Installation guide (moved)',
		content: `<h1>Installation guide</h1>${movedToRepoDocs}`,
	},
	'2_SETUP_FLOWS': {
		title: '⚙️ Setup flows (moved)',
		content: `<h1>Setup flows</h1>${movedToRepoDocs}`,
	},
	'3_DEV_FLOWS': {
		title: '🔄 Development flows (moved)',
		content: `<h1>Development flows</h1>${movedToRepoDocs}`,
	},
	'4_INTERSHELL': {
		title: '📝 Scripting (moved)',
		content: `<h1>Scripting</h1>${movedToScripting}`,
	},
	'5_DOCKER': {
		title: '🐳 Docker',
		content: `<h1>Docker</h1>${dockerComposeNote}`,
	},
	'6_RENOVATE': {
		title: '🔄 Renovate',
		content: `<h1>Renovate</h1>${renovateNote}`,
	},
	'7_AUTO_VERSIONING': {
		title: '🏷️ Auto versioning (moved)',
		content: `<h1>Auto versioning</h1>${movedToAutoVersioning}`,
	},
	TESTING: {
		title: '🧪 Testing',
		content:
			'<h1>Testing</h1><p>See <code>.cursor/rules/testing.mdc</code> and <code>tools/tests-preset/AGENTS.md</code> in the repository.</p>',
	},
	AI_Prompt: {
		title: '🤖 AI Prompt',
		content:
			'<h1>AI Prompt</h1><p>This page contains AI prompt information for the project.</p>',
	},
};

const docInfo = docContent[doc] || {
	title: doc,
	content: `<h1>${doc}</h1><p>Documentation page for ${doc}.</p>`,
};

title = docInfo.title;
content = docInfo.content;
---

<Layout title={title}>
	<div class='bg-white shadow-sm border-b border-gray-200'>
		<div class='max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8'>
			<div class='prose prose-lg max-w-none'>
				<div set:html={content} />
			</div>
		</div>
	</div>
</Layout>
