	},
	"devDependencies": {
		"@astrojs/check": "0.9.9",
		"@repo/typescript-config": "workspace:*",
		"@types/bun": "1.3.14",
		"@tailwindcss/vite": "4.3.0",
		"tailwindcss": "4.3.0",
		"typescript": "6.0.3"
