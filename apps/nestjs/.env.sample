# @apps/nestjs — copy to .env (see root .env.sample for compose substitution)
HOST=0.0.0.0
NESTJS_PORT=3006
PORT=3006
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3002
NODE_ENV=development
DATABASE_URL=postgresql://monobun:monobun@postgres:5432/monobun

# JWT from @apps/auth (see root .env.sample)
AUTH_JWKS_URL=http://localhost:3007/.well-known/jwks.json
AUTH_ISSUER=http://localhost:3007
AUTH_AUDIENCE=monobun-api
AUTH_ALLOW_HEADER_TENANT=true
