{
	"private": false,
	"version": "0.1.0",
	"name": "@apps/nestjs",
	"description": "NestJS control-plane API for multi-tenant feature flags",
	"type": "module",
	"scripts": {
		"postinstall": "bun run db:generate",
		"dev": "NODE_ENV=development tsup --watch --onSuccess 'bun dist/index.js'",
		"build": "tsup",
		"start": "bun dist/index.js",
		"typecheck": "bun run db:generate && tsc --noEmit",
		"test": "bun test src/__tests__",
		"openapi:emit": "NODE_ENV=development bun dist/index.js --emit-openapi",
		"db:generate": "bunx --bun prisma generate",
		"db:migrate": "bunx --bun prisma migrate dev",
		"db:migrate:deploy": "bunx --bun prisma migrate deploy",
		"db:seed": "bun scripts/seed.ts",
		"db:studio": "bunx --bun prisma studio"
	},
	"dependencies": {
		"@anatine/esbuild-decorators": "0.2.19",
		"@nestjs/common": "11.1.21",
		"@nestjs/core": "11.1.21",
		"@nestjs/platform-express": "11.1.21",
		"@nestjs/swagger": "11.4.3",
		"@packages/utils": "workspace:*",
		"@prisma/adapter-pg": "7.1.0",
		"@prisma/client": "7.1.0",
		"pg": "8.16.3",
		"reflect-metadata": "0.2.2",
		"rxjs": "7.8.2",
		"zod": "4.4.3"
	},
	"devDependencies": {
		"@types/pg": "8.15.6",
		"@nestjs/testing": "11.1.21",
		"prisma": "7.1.0",
		"@tools/tests-preset": "workspace:*",
		"@tools/typescript": "workspace:*",
		"@types/express": "5.0.6",
		"@types/supertest": "7.2.0",
		"supertest": "7.2.2",
		"tsup": "8.5.1"
	}
}
