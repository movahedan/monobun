# @apps/auth — copy to .env (see root .env.sample for compose substitution)
HOST=0.0.0.0
AUTH_PORT=3007
PORT=3007
NODE_ENV=development

AUTH_ISSUER=http://localhost:3007
AUTH_AUDIENCE=monobun-api
AUTH_AUDIENCE_EVAL=monobun-eval
AUTH_ACCESS_TTL_SECONDS=900

AUTH_DATABASE_URL=postgresql://monobun:monobun@localhost:5432/monobun_auth

AUTH_COOKIE_SESSION=auth_session
AUTH_COOKIE_REFRESH=auth_refresh
AUTH_COOKIE_CSRF=auth_csrf
AUTH_COOKIE_SECURE=false

# PEM strings or paths (dev: scripts/generate-dev-keys.ts writes dev-keys/*.pem)
AUTH_JWT_PRIVATE_KEY=./dev-keys/private.pem
AUTH_JWT_PUBLIC_KEY=./dev-keys/public.pem

# Seed credentials (db:seed)
AUTH_SEED_ADMIN_EMAIL=admin@example.com
AUTH_SEED_ADMIN_PASSWORD=changeme
