{
	"private": true,
	"name": "@repo/ui",
	"type": "module",
	"main": "./src/index.ts",
	"files": [
		"src/**"
	],
	"exports": {
		"./login-form": "./src/login-form/login-form.tsx",
		"./card": "./src/card/card.tsx",
		"./input": "./src/input/input.tsx",
		"./label": "./src/label/label.tsx",
		"./button": "./src/button/button.tsx",
		"./link": "./src/link/link.tsx",
		"./counter-button": "./src/counter-button/counter-button.tsx",
		".": "./src/index.ts"
	},
	"scripts": {
		"typecheck": "tsc --noEmit",
		"watch:exports": "bun --no-clear-screen --watch ./scripts/watch-export-modules.ts",
		"dev": "bun run watch:exports & WATCH_PID=$!; bun run dev:storybook; kill \"$WATCH_PID\" 2>/dev/null || true",
		"dev:storybook": "bunx --bun storybook dev --no-open --port 3004",
		"prebuild": "bun ../../scripts/export-modules/index.tsx update --pattern '^src/(?:index\\.tsx?|([^/]+)/\\1\\.tsx)$' --regex-flags 'i'",
		"build:storybook": "bunx --bun storybook build -o dist-storybook",
		"start": "bun run build:storybook && bunx --bun serve dist-storybook"
	},
	"dependencies": {
		"@radix-ui/react-label": "2.1.8",
		"@radix-ui/react-slot": "1.2.4",
		"@repo/utils": "workspace:*",
		"@types/react": "19.2.14",
		"@types/react-dom": "19.2.3",
		"class-variance-authority": "0.7.1",
		"clsx": "2.1.1",
		"lucide-react": "1.16.0",
		"react": "19.2.6",
		"react-dom": "19.2.6",
		"tailwind-merge": "3.6.0"
	},
	"devDependencies": {
		"@repo/config-tests": "workspace:*",
		"@repo/config-typescript": "workspace:*",
		"@types/bun": "1.3.14",
		"@storybook/addon-a11y": "10.4.0",
		"@storybook/addon-links": "10.4.0",
		"@storybook/addon-themes": "10.4.0",
		"@storybook/react": "10.4.0",
		"@storybook/react-vite": "10.4.0",
		"@storybook/testing-library": "0.2.2",
		"autoprefixer": "10.5.0",
		"serve": "14.2.6",
		"storybook": "10.4.0",
		"tailwindcss": "4.3.0",
		"tailwindcss-animate": "1.0.7"
	}
}
