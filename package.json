{
	"root": true,
	"private": false,
	"name": "root",
	"description": "A monorepo for Turbo and Bun",
	"version": "0.2.2",
	"workspaces": [
		"apps/*",
		"packages/*",
		"scripts"
	],
	"packageManager": "bun@1.3.1",
	"engines": {
		"node": ">=25.0.0"
	},
	"intershell": {
		"config": "intershell.config.json"
	},
	"scripts": {
		"postinstall": "lefthook install",
		"nuke": "bun scripts/nuke/index.tsx",
		"local": "bun scripts/local/index.tsx",
		"turbo": "turbo",
		"lint": "biome check .",
		"typecheck": "turbo run typecheck",
		"test": "bun test",
		"build": "turbo run build",
		"overall": "bun scripts/overall/index.tsx",
		"container": "bun scripts/container/index.tsx",
		"release": "bun scripts/version/index.tsx",
		"export-modules": "bun scripts/export-modules/index.tsx",
		"precommit": "bun scripts/precommit/index.tsx",
		"ci": "bun scripts/ci/index.tsx"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.15",
		"@types/bun": "1.3.14",
		"@types/react": "19.2.14",
		"ink": "7.0.3",
		"intershell": "0.6.2",
		"lefthook": "2.1.6",
		"react": "19.2.6",
		"safe-regex": "2.1.1",
		"turbo": "2.9.14",
		"typescript": "6.0.3"
	},
	"overrides": {
		"@types/node": "25.8.0",
		"@types/react": "19.2.14",
		"@types/react-dom": "19.2.3",
		"typescript": "6.0.3",
		"react": "19.2.6",
		"react-dom": "19.2.6",
		"vite": "8.0.13"
	},
	"author": "Soheil Movahedan",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/movahedan/monobun"
	},
	"homepage": "https://github.com/movahedan/monobun",
	"bugs": "https://github.com/movahedan/monobun/issues",
	"keywords": [
		"turbo",
		"bun",
		"monorepo",
		"typescript",
		"react",
		"docker",
		"git",
		"vite"
	]
}
