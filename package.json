{
	"root": true,
	"private": false,
	"name": "root",
	"description": "A monorepo for Turbo and Bun",
	"version": "0.2.2",
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"packageManager": "bun@1.3.1",
	"intershell": {
		"config": "intershell.config.ts"
	},
	"scripts": {
		"postinstall": "lefthook install",
		"local": "bun scripts/local/index.tsx",
		"turbo": "turbo",
		"lint": "biome check .",
		"typecheck": "turbo run typecheck",
		"test": "bun test",
		"build": "turbo run build",
		"overall": "bun scripts/overall/index.tsx",
		"container": "bun scripts/container/index.tsx",
		"release": "bun scripts/version/index.tsx",
		"export-modules": "bun scripts/export-modules/index.tsx",
		"precommit": "bun scripts/precommit/index.tsx",
		"ci": "bun scripts/ci/index.tsx"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.8",
		"@types/bun": "1.3.14",
		"@types/react": "19.2.2",
		"ink": "7.0.3",
		"intershell": "0.6.1",
		"lefthook": "1.12.4",
		"react": "19.2.0",
		"turbo": "2.5.8",
		"typescript": "5.9.3"
	},
	"overrides": {
		"@types/react": "19.2.2",
		"@types/react-dom": "19.2.2",
		"typescript": "5.9.3",
		"react": "19.2.0",
		"react-dom": "19.2.0",
		"vite": "7.1.11"
	},
	"author": "Soheil Movahedan",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/movahedan/monobun"
	},
	"homepage": "https://github.com/movahedan/monobun",
	"bugs": "https://github.com/movahedan/monobun/issues",
	"keywords": [
		"turbo",
		"bun",
		"monorepo",
		"typescript",
		"react",
		"docker",
		"git",
		"vite"
	]
}
