{
	"$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true,
		"defaultBranch": "main"
	},
	"files": {
		"ignoreUnknown": false,
		"includes": [
			"**",
			"!bun.lock",
			"!renovate.json",
			"!**/node_modules",
			"!**/dist",
			"!**/build",
			"!**/out",
			"!**/.turbo",
			"!**/.next",
			"!**/.vercel",
			"!**/.act",
			"!.act-event.json",
			"!**/src/generated"
		]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"lineWidth": 100
	},
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"organizeImports": {
					"level": "on",
					"options": {
						"groups": [
							[":BUN:", ":NODE:"],
							":BLANK_LINE:",
							[
								":URL:",
								":PACKAGE_WITH_PROTOCOL:",
								":PACKAGE:",
								"!@packages/**",
								"!@tools/**",
								"!@apps/**",
								"!#/**"
							],
							":BLANK_LINE:",
							["@packages/**", "@tools/**", "@apps/**"],
							":BLANK_LINE:",
							["#/**"],
							":BLANK_LINE:",
							[":ALIAS:", ":PATH:", "!#/**", "!**/*.css", "!**/*.scss", "!**/*.sass"],
							":BLANK_LINE:",
							["**/*.css", "**/*.scss", "**/*.sass"]
						]
					}
				}
			}
		}
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"correctness": {
				"useHookAtTopLevel": "error",
				"noUnusedImports": "error"
			},
			"style": {
				"useLiteralEnumMembers": "error",
				"useNodejsImportProtocol": "error",
				"useAsConstAssertion": "error",
				"useEnumInitializers": "error",
				"useSelfClosingElements": "error",
				"useConst": "error",
				"useSingleVarDeclarator": "error",
				"noUnusedTemplateLiteral": "error",
				"useNumberNamespace": "error",
				"noInferrableTypes": "error",
				"useExponentiationOperator": "error",
				"useTemplate": "error",
				"noParameterAssign": "error",
				"noNonNullAssertion": "error",
				"useDefaultParameterLast": "error",
				"useImportType": "error",
				"useExportType": "error",
				"noUselessElse": "error",
				"useShorthandFunctionType": "error"
			},
			"suspicious": {
				"noExplicitAny": "error",
				"noUnknownAtRules": "off"
			}
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double"
		}
	},
	"css": {
		"parser": {
			"tailwindDirectives": true
		}
	}
}
